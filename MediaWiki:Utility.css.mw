/*
Utility.css contains CSS classes which are not design relevant for the specific wiki
Rather there are functional and best practice CSS constructs which without modification
can be helpful on other wikis too (see especially Categoy:MultiWiki)
*/

/* -------------- */
/* 1. Boilerplate */

a {
	overflow-wrap: break-word;
}

.modal {
	/* makes position: fixed work on old mobile web browsers */
	-webkit-backface-visibility: hidden;
}

body.modal-open {
    overflow: visible;
}

.mw-workspace-container {
	max-width: unset;
}

/* Flagged revisions Bottom bar */

#mw-data-after-content {
	position: absolute;
	background: white;
	width: 235px;
	margin-top: 55px;
	padding: 0 10px;
	margin-left: 10px;
	z-index: 10;
}

#mw-data-after-content #mw-fr-reviewform #mw-fr-ratingselects {
	white-space: break-spaces;
}

#mw-data-after-content #mw-fr-reviewform #mw-fr-confirmreview input  {
	width: 100%;
}

#footer {
	display: none;
}

/* ---------------------------- */
/* 2. General purpose Utilities */

.width-100 {
	width: 100%;
}

.margin-left-5 { margin-left: 5px; }
.margin-left-10 { margin-left: 10px; }
.margin-left-20 { margin-left: 20px; }
.margin-right-5 { margin-right: 5px; }
.margin-right-10 { margin-right: 10px; }
.margin-right-20 { margin-right: 20px; }
.margin-top-5 { margin-top: 5px; }
.margin-top-10 { margin-top: 10px; }
.margin-top-20 { margin-top: 20px; }
.margin-bottom-5 { margin-bottom: 5px; }
.margin-bottom-10 { margin-bottom: 10px; }
.margin-bottom-20 { margin-bottom: 20px; }

.pos-1px-up { position: relative; top: -1px; }
.pos-1px-down { position: relative; top: 1px; }
.pos-2px-up { position: relative; top: -2px; }
.pos-2px-down { position: relative; top: 2px; }
.pos-3px-up { position: relative; top: -3px; }
.pos-3px-down { position: relative; top: 3px; }

.text-align-center {
	text-align: center;
}

.vertical-align-middle {
	vertical-align: middle;
}

.clear-float {
	clear: both;
	float: none;
	overflow: auto;
}

/* -------------------------------------------------------- */
/* 3. Fix: overlapping of fixed header on page target jumps */

html, body {
	scroll-padding-top: 70px;
}

.mw-headline {
	padding-top: 70px;
	background-color: transparent !important;
}

sup[id^=cite_ref-] {
	padding-top: 90px;
	background-color: transparent !important;
}

li[id^=cite_note-]:target {
	content: '';
	padding-top: 70px;
	margin-top: -70px;
	background-color: transparent !important;
}

li[id^=cite_note-]:target > .reference-text {
	background-color: #ececec;
}

/* ------------------------------- */
/* 4. Manually place anchor Utiliy */

.manually-placed-anchor {
	position: relative;
	top: -40px;
}

/* ---------------------- */
/* 5. Thumbs Modification */

.thumb {
	margin-top: 0 !important;
	max-width: 100%;
	vertical-align: top;
}
	
.thumb .thumbinner {
	border-radius: 5px;
	padding: 5px !important;
	max-width: 100%;
}

.thumb .thumbinner a.image {
	width: 100%;
	display: block;
}

.thumb .thumbinner img {
	max-width: 100%;
	height: auto;
}

.thumb .thumbimage.hide-enlarge + .thumbcaption {
	text-align: center;
}

.thumb .thumbimage.hide-enlarge + .thumbcaption .magnify {
	display: none;
}

/* ----------------------- */
/* 6. Scroll-Table Utility */

#mw-content-text .scroll-table {
	overflow-x: auto;
	max-width: 100%;
	position: relative;
	margin: 1em 0;
}

#mw-content-text .scroll-table table {
	margin: 0;
}

#mw-content-text .scroll-table.scroll-overflow-indicator {
	padding-bottom: 11px;
}

#mw-content-text .scroll-table.scroll-overflow-indicator:before, #mw-content-text .scroll-table.scroll-overflow-indicator:after {
	content: 'swipe >>';
	display: block;
	width: 100%;
	padding: 2px 15px 5px;
	color: white;
	background: linear-gradient( to right, #6ab9ff 30%, transparent);
	border-radius: 4px;
	font-size: 17px;
}

/* ---------------- */
/* 7. No-JS classes */

.show-for-nojs-only {
	display: none;
}

.show-for-js-only {
	display: block;
}

/* ------------------ */
/* 8. Columns Utility */

.use-2-columns, .use-3-columns {
	column-gap: 20px;
	column-rule: 1px solid #ddd;
	width: 100%;
	margin: 15px 0;
}

.use-2-columns {
	column-count: 2;
}

.use-3-columns {
	column-count: 3;
}
	
.use-2-columns .keep-together, .use-3-columns .keep-together {
	display: inline-block;
	vertical-align: top;
}

.use-3-columns.strict-list-columns > ul,
.use-3-columns.strict-list-columns > ol {
	display: inline-block;
}

/* Responsive */
@media (max-width: 590px) {
	.use-3-columns {
		column-count: 2;
	}
}

@media (max-width: 450px) {
	.use-2-columns, .use-3-columns {
		column-count: 1;
	}
}

