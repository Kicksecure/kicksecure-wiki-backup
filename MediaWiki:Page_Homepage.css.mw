/* 1. General */

body {
	background-image: linear-gradient(90deg, #c8e4ed, #fafaff 25%, #fafaff 75%, #c8e4ed 100% );
}

#siteNotice, #firstHeading {
	display: none;
}

#mw-content-text {
	padding-top: 30px;
}

.sections-wrapper h2 {
	font-size: 30px !important;
	text-align: center;
	border-bottom: none;
	margin-bottom: 45px !important;
}

.sections-wrapper h2 a {
	font-size: inherit !important;
}

.sections-wrapper p, .sections-wrapper a, .sections-wrapper span {
	font-size: 17px !important;
}

.mw-collapsible {
	padding-left: 0;
	padding-right: 0;
}

.inner-wrapper {
	margin-left: auto;
	margin-right: auto;
}

/* 1.1. Dark Section */

.dark-section {
	background: #3a3370;
	color: white;
	text-align: center;
	padding: 1px 0 31px;
	margin-left: calc(50% - 50vw);
	margin-right: calc(50% - 50vw + 8px);
}

.dark-section > .inner-wrapper {
	max-width: 960px;
}

.dark-section h2, .dark-section p {
	color: white !important;
}

.dark-section p {
	margin: 30px 0 !important;
}

.dark-section a:not(.mw-collapsible-text) {
	color: #6fa5ff !important;
}

/* 1.2. Section with [div] rows */

.row-div-section {
	font-size: 0;
	text-align: center;
}

.row-div-section .inner-wrapper > div:not(.mw-collapsible), .row-div-section .mw-collapsible .mw-collapsible-content > div {
	display: inline-block;
	vertical-align: top;
	text-align: justify;	
}

.row-div-section .inner-wrapper > div:not(.mw-collapsible) i,
.row-div-section .inner-wrapper > div:not(.mw-collapsible) a.image,
.row-div-section .inner-wrapper > .mw-collapsible .mw-collapsible-content > div i,
.row-div-section .inner-wrapper > .mw-collapsible .mw-collapsible-content > div a.image
{
	height: 150px;
	width: 100%;
	display: block;
	background-size: contain;
	background-repeat: no-repeat;
	background-position: center center;
}

.row-div-section .inner-wrapper > div:not(.mw-collapsible) .image-cover,
.row-div-section .inner-wrapper > .mw-collapsible .mw-collapsible-content > div .image-cover {
	background-size: cover !important;
}

.row-div-section .inner-wrapper > div > h4, .row-div-section .mw-collapsible h4 {
	font-size: 19px !important;
	margin: 10px 0 0 !important;
	text-align: center;
}

.row-div-section .mw-collapsible > h4 {
	background-color: #e0e0e0 !important;
	border-radius: 8px;
	position: relative;
	top: -6px;
	line-height: 34px;
    padding-top: 3px;
}

.row-div-section .mw-collapsible:not(.mw-collapsed) > .mw-collapsible-toggle, .row-div-section .mw-collapsible:not(.mw-collapsed) > h4 {
	display: none;
}

/* 1.3. Section with [a] rows */

.row-a-section {
	text-align: center;
	font-size: 0;
}

.row-a-section .inner-wrapper > a, .row-a-section .inner-wrapper > a:visited {
	display: inline-block;
	vertical-align: top;
	margin-bottom: 20px;
	transition: transform .3s;
	color: #333 !important;
}

.row-a-section .inner-wrapper > a:hover {
	transform: scale(1.1);
}

.row-a-section .inner-wrapper > a span {
	text-align: center;
	display: block;
	margin-top: 10px;
}

/* 1.4. Row sizes */

.row-3-section > .inner-wrapper > div, .row-3-section > .inner-wrapper > a {
	width: 30%;
	margin: 1.5%;
}

.row-4-section > .inner-wrapper > div, .row-4-section > .inner-wrapper > a {
	width: 24%;
	margin: .3%;
}

.row-5-section > .inner-wrapper > div, .row-5-section > .inner-wrapper > a {
	width: 18%;
	margin: .3%;
}

/* 2. Section Banner */

.section-banner {
	width: 100%;
	padding-bottom: 10px;
}

.section-banner .logo {
	text-align: center;
	width: 100%;
	max-width: 400px;
	display: block;
	margin: auto;
}

.section-banner .logo img {
	width: 100%;
}

.section-banner h2 {
	margin: 33px 0 !important;
	font-size: 22px !important;
}

.section-banner .overview-image {
	max-width: 100%;
	border-radius: 3vw;
	box-shadow: 3px 3px 6px 2px rgba(0,0,0,.1);
	border: 1px solid #ccc;
}

/* 3. Section Download */

.section-download {
	padding: 1px 60px 40px;
}

.section-download .inner-wrapper > div a {
	background: rgba(0,0,0,.3);
	display: block;
	width: 100%;
	border-radius: 20px;
	vertical-align: top;
	text-decoration: none;
	transition: transform .3s;
	padding: 10px;
}

.section-download .inner-wrapper > div a:hover {
	transform: scale(1.1);
}

.section-download .inner-wrapper > div a span {
	display: block;
	margin-top: 10px;
	color: white;
	text-align: center;
}

/* 4. Section Press */

.section-press {
	text-align: center;
	padding: 44px 0;
}

.section-press .inner-wrapper > div i  {
	height: 100px !important;
	margin-bottom: 20px;
	background-size: contain !important;
}

.section-press .inner-wrapper > div span {
	position: relative;
	display: inline-block;
}

.section-press .inner-wrapper > div span:before {
	content: '"';
	font-size: 48px;
	line-height: 34px;
	height: 22px;
	float: left;
	margin-right: 7px;
}

.section-press .inner-wrapper > div span a {
	background: #ddd;
	border-radius: 3px;
	padding: 0 2px;
	color: black;
	display: inline-block;
	text-decoration: none;
}

.section-press .inner-wrapper > div span a:hover {
	transform: scale(1.5);
}

/* 5. Section Explain */

.section-explain {
	padding: 1px 50px 10px;
	text-align: center;
}

.section-explain .inner-wrapper > * {
	max-width: 800px;
	margin-left: auto !important;
	margin-right: auto !important;
}

.section-explain .illustration {
	background: #f6f3f4;
	border-radius: 30px;
	padding: 40px 30px 20px;
	margin: auto;
}

.section-explain .illustration img {
	width: 100%;
}

.section-explain p {
	position: relative;
	top: -20px;
}

/* 6. Section App */

.section-apps {
	padding: 10px 0 30px;
}

/* 7. Section Features */

.section-features  {
	margin-top: 10px;
	margin-bottom: 50px;
}


/* 8. Section Upcoming */

.section-upcoming {
	padding: 1px 60px 40px;
	margin-top: 40px;
	margin-bottom: 40px;
}

.section-upcoming .inner-wrapper > div:not(.mw-collapsible) {
	transition: transform .3s;
}

.section-upcoming .inner-wrapper > div:not(.mw-collapsible):hover {
	transform: scale(1.1);
}

.section-upcoming a {
	text-decoration: none;
}

.section-upcoming span {
	color: white;
	margin-top: 15px;
	display: block;
}

/* 9. Section Investor */

.section-investor {
	margin-top: 40px;
	margin-bottom: 40px;
	padding: 1px 60px 40px;
}

.section-investor h2 {
	margin-bottom: 15px !important;
}

.section-investor img {
	width: 100%;
	max-width: 900px;
}

/* 10. Help */

.section-help i {
	height: 250px !important;
	margin-bottom: 20px;
}

/* ----------- */
/* Other Sizes */

@media (max-width: 650px) {
	.row-5-section .inner-wrapper > div, .row-5-section .inner-wrapper > a {
		width: 23%;
		margin:.8%;
	}
}

@media (max-width: 500px) {
	.section-download, .section-upcoming {
		padding-left: 20px;
		padding-right: 20px;
	}
	.section-download .os {
		width: 45%;
	}
	.row-3-section .inner-wrapper > *:not(.mw-collapsible), .row-3-section .inner-wrapper > .mw-collapsible .mw-collapsible-content > * {
		width: 45%;
		margin-left: 2.5%;
		margin-right: 2.5%;
	}
	.row-5-section .inner-wrapper > div, .row-5-section .inner-wrapper > a {
		width: 30%;
	}
}

@media (max-width: 400px) {
	.row-3-section:not(.section-download) .inner-wrapper > *:not(.mw-collapsible), .row-3-section .inner-wrapper > .mw-collapsible .mw-collapsible-content > * {
		width: 100%;
		margin-left: 0;
		margin-right: 0;
	}
	.row-5-section .inner-wrapper > div, .row-5-section .inner-wrapper > a {
		width: 45%;
	}
	.section-press .inner-wrapper > div {
		margin-bottom: 40px !important;
	}
}
