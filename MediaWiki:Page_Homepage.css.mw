/* 1. General */

body {
	background-image: linear-gradient(90deg, #c8e4ed, #fafaff 25%, #fafaff 75%, #c8e4ed 100% );
}

a[disabled] {
	cursor: default;
}

#siteNotice, #firstHeading {
	display: none;
}

#mw-content-text {
	padding-top: 30px;
}

.sections-wrapper h2 {
	font-size: 30px !important;
	text-align: center;
	border-bottom: none;
	margin-bottom: 45px !important;
}

.sections-wrapper h2 a {
	font-size: inherit !important;
}

.sections-wrapper p, .sections-wrapper a, .sections-wrapper span {
	font-size: 17px !important;
}

#mw-content-text .mw-collapsible {
	padding-left: 0;
	padding-right: 0;
	overflow: visible;
}

#mw-content-text .mw-collapsible > h4 {
	background-color: #e0e0e0 !important;
	border-radius: 8px;
	position: relative;
	top: -16px;
	line-height: 34px;
    padding: 4px 0 6px;
    text-align: center;
    font-size: 19px;
}

#mw-content-text .mw-collapsible > .mw-collapsible-toggle {
	line-height: 34px;
}

#mw-content-text .mw-collapsible:not(.mw-collapsed) > .mw-collapsible-toggle, #mw-content-text .mw-collapsible:not(.mw-collapsed) > h4 {
	display: none;
}

.inner-wrapper {
	margin-left: auto;
	margin-right: auto;
}

/* 1.1. Dark Section */

.dark-section {
	background: #3a3370;
	color: white;
	text-align: center;
	padding: 1px 0 31px;
	margin-left: calc(50% - 50vw);
	margin-right: calc(50% - 50vw + 8px);
	margin-top: 10px;
	margin-bottom: 0px;
}

.dark-section > .inner-wrapper {
	max-width: 960px;
}

.dark-section > .inner-wrapper > h2, .dark-section > .inner-wrapper > p {
	color: white !important;
}

.dark-section a:not(.mw-collapsible-text) {
	color: #6fa5ff !important;
}

/* 1.2. Item row (rows of items in columns) */

.item-row {
	font-size: 0;
	text-align: center;
}

.item-row > *:not(.no-item) {
	display: inline-block;
	vertical-align: top;
	text-align: center;	
}


.item-row > *:not(.no-item) i, .item-row > *:not(.no-item) a.image {
	height: 150px;
	width: 100%;
	display: block;
	background-size: contain;
	background-repeat: no-repeat;
	background-position: center center;
}

.item-row > *:not(.no-item) i.image-cover, .item-row > *:not(.no-item) a.image.image-cover {
	background-size: cover !important;
}

.item-row > *:not(.no-item) h4, .item-row > *:not(.no-item) h4 {
	font-size: 19px !important;
	margin: 10px 0 0 !important;
	text-align: center;
}

.item-row.scale-on-hover > *:not(.no-item) {
	transition: transform .3s;
}

.item-row.scale-on-hover > *:not(.no-item):hover {
	transform: scale( 1.1 );
}

/* 1.3. Row sizes */

.item-row-3 > *:not(.no-item) {
	width: 30.33%;
	margin: 1.5%;
}

.item-row-4 > *:not(.no-item) {
	width: 23%;
	margin: 1%;
}

.item-row-5 > *:not(.no-item) {
	width: 19%;
	margin: .5%;
}

/* 1.4. Screen Sizes */


@media (max-width: 650px) {
	.item-row-5 > *:not(.no-item) {
		width: 23%;
		margin: 1%;
	}
}

@media (max-width: 500px) {
	.item-row-5 > *:not(.no-item), .item-row-4 > *:not(.no-item) {
		width: 30.33%;
		margin: 1.5%;
	}
}

@media (max-width: 400px) {
	.item-row-5 > *:not(.no-item), .item-row-4 > *:not(.no-item), .item-row-3 > *:not(.no-item) {
		width: 45%;
		margin: 2.5%;
	}
}

/* 2. Section Banner */

.section-banner {
	width: 100%;
	padding-bottom: 10px;
}

.section-banner .logo {
	text-align: center;
	width: 100%;
	max-width: 400px;
	display: block;
	margin: auto;
}

.section-banner .logo img {
	width: 100%;
}

.section-banner h2 {
	margin: 33px 0 !important;
	font-size: 22px !important;
}

.section-banner .overview-image {
	max-width: 100%;
	border-radius: 3vw;
	box-shadow: 3px 3px 6px 2px rgba(0,0,0,.1);
	border: 1px solid #ccc;
}

/* 3. Section Download */

.section-download {
	padding: 1px 60px 40px;
}

.section-download .inner-wrapper > div a {
	background: rgba(0,0,0,.3);
	display: block;
	width: 100%;
	border-radius: 20px;
	vertical-align: top;
	text-decoration: none;
	padding: 10px;
}

.section-download .inner-wrapper > div a span {
	display: block;
	margin-top: 10px;
	color: white;
	text-align: center;
}

/* 4. Section Navi */

.section-navi {
	padding: 40px 0;
}

.section-navi .inner-wrapper > div > a {
	width: 100%;
	background: #def;
	border-radius: 10px;
	text-align: center;
	display: inline-block;
	padding: 10px 0;
	font-size: 20px !important;
}

.section-navi .inner-wrapper > div > a:hover {
	text-decoration: none;
	box-shadow: 0 0 2px 1px rgba(0,0,0,.15);
}

/* 5. Section Apps */

.section-apps {
	padding: 10px 0 40px;
}

.section-apps a {
	text-align: center;
}

.section-apps span {
	color: white;
	width: 100%;
	display: inline-block;
	margin-top: 10px;
}

/* 6. Section Features */

.section-features {
	margin-top: 40px;
}

.section-features .item-row > div p {
	text-align: justify;
}

.section-features .live-mode a.image {
	background-color: black;
}

/* 6.1. Section values */

.section-values .research-project a.image {
	background-color: #b1dcfb;
}

/* 7. Section Upcoming */

.section-upcoming {
	padding: 25px;
	margin-top: 40px;
}

.section-upcoming a {
	text-decoration: none;
	transition: color .3s;
}

.section-upcoming a:not(:hover) {
	color: white !important;
}

.section-upcoming i {
	margin-bottom: 15px;
}

.section-upcoming span {
	text-align: justify;
	display: block;
}

.section-upcoming .lkrg i {
	background-color: black;
}

/* 8. Section Investor */

.section-investor {
	padding: 1px 60px 40px;
}

.section-investor h2 {
	margin: 25px 0 30px !important;
}

.section-investor img {
	width: 100%;
	max-width: 900px;
}

.section-investor p {
	text-align: center;
	font-size: 19px !important;
	margin-top: 25px !important;
}

.section-investor a img {
	transition: transform .3s;	
}

.section-investor a:hover img {
	transform: scale( 1.05 );
}

/* 9. Section Help */

.section-help h2 {
	margin-bottom: 15px !important;
}

.section-help i {
	height: 250px !important;
	margin-bottom: 20px;
}