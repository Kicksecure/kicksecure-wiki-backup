<!--{* WARNING: DO NOT CALL THIS WIDGET DIRECTLY. THE PARAMETERS NEED TO BE SANATIZIED BY THE TEMPLATE *}-->

<!--{assign var="isEndOfYear" value=$special == 'end-of-year'}-->
<!--{assign var="isDecember" value=$currentMonth == 12}-->
<!--{assign var="hasMandatoryParams" value=$id !== '' && $html !== ''}-->

<!--{assign var="showBanner" value=true}-->

<!--{if $expires !== '' && $expires <= time() || $isEndOfYear && ! $isDecember}-->
  <!--{assign var="showBanner" value=false}-->
<!--{/if}-->

<!--{if ! $hasMandatoryParams}-->
  <!--{assign var="showBanner" value=true}-->
<!--{/if}-->

<!--{if $showBanner}-->
  <div class="sitenotice-banner<!--{if $isEndOfYear}--> sitenotice-end-of-year<!--{/if}--> robots-nocontent" data-banner-id="<!--{if $id !== ''}--><!--{$id}--><!--{else}-->missing-id<!--{/if}-->">
    <!--googleoff: index--><!--noindex-->
    <!--{if ! $hasMandatoryParams}-->
      <div class="error">Widget SitenoticeBanner Error: Missing mandatory parameters. Required: <code>id</code>, <code>html</code>.</div>
    <!--{else}-->
      <!--{if $href !== '' }--><a href="<!--{$href}-->"><!--{/if}-->
        <div class="sitenotice-banner-content"><!--{$html}--></div>
      <!--{if $href !== '' }--></a><!--{/if}-->
    <!--{/if}-->
    <!--/noindex--><!--googleon: index-->
  </div>
<!--{/if}-->

<!--{if $isEndOfYear}-->
  <!--{assign var="addressesRaw" value=$crypto|default:''}-->

  <!--{if $addressesRaw !== ''}-->
    <!--{assign var="pairs" value=','|explode:$addressesRaw}-->
    <!--{foreach from=$pairs item="pair"}-->
      <!--{assign var="parts" value=':'|explode:$pair}-->
        
      <!--{if $parts|@count == 2}-->
        <p>
          <strong><!--{$parts[0]}--></strong>: 
          <code><!--{$parts[1]}--></code>
        </p>
      <!--{/if}-->
    <!--{/foreach}-->
  <!--{/if}-->
<!--{/if}-->