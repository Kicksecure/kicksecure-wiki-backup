/* Documentation see: /wiki/Widget:Download_Button */

(function() {
	
	// Events
	
	$('.download-button-v2').each( function() {
		if($(this).attr('data-redirect')) {
			let redirect = $(this).attr('data-redirect').split(',');
			$(this).on( 'click', function() {
				setTimeout( function() {
					window.location = redirect[0];
				}, parseInt( redirect[1] ) )
			});
		}
	});
	
})();
