/* All styles for Widget:Sitenotice */

/* 1. General SiteNotice */

#siteNotice {
	margin-top: 30px;
	display: block;
}

#siteNotice .mw-dismissable-notice-body {
	margin: 0;
}

#siteNotice .mw-dismissable-notice-close {
	position: absolute;
	right: 5px;
	top: 3px;
	display: none;
}

#siteNotice .mw-dismissable-notice-close a {
	font-size: 20px;
	color: #555;
	padding: 0 8px;
}

#siteNotice .mw-dismissable-notice-close a:hover i {
	transform: scale(1.2);
	color: black;
}

/* 2. All Banners */

#siteNotice .active-banner {
	display: block;
}
	
#siteNotice .active-banner > * {
	vertical-align: middle;
}

/* 3. Specific Banners */

#siteNotice .active-banner-01 {
	padding: 5px 0;
	background: linear-gradient( #22a7dF, #43b3f1 );
	color: white;
	font-size: 20px;
    border-radius: 10px;
    border: 1px solid #22a7dF;
    text-decoration: none;
}

#siteNotice .active-banner-01:hover {
	background: linear-gradient( #1297cF, #43b3f1 );
}

#siteNotice .active-banner-01 .icon {
	margin-right: 13px;
	height: 40px;
}

#siteNotice .active-banner-01 span {
	position: relative;
	top: 1px;
}

#siteNotice .active-banner-02 {
	border-radius: 10px;
	overflow: hidden;
	box-shadow: 2px 2px 4px rgba(0,0,0,.2);
}

#siteNotice .active-banner-02 img {
	width: 100%;
}
