/* ---------- */
/* 1. General */

.mw-header {
	display: none;
}

#custom-header {
	background: white;
	position: fixed;
	/* makes position: fixed work on old mobile web browsers */
	-webkit-backface-visibility: hidden;
	height: 50px;
	top: 0;
	left: 0;
	width: 100%;
	z-index: 1000;
	box-shadow: 2px 2px 4px rgba(0,0,0,.1);
}

#custom-header .style-wrapper {
	width: 100%;
	max-width: 960px;
	background: transparent;
	margin: auto;
	height: 100%;
	position: relative;
}

#custom-header .style-wrapper > * {
	vertical-align: top;
}

/* 1.1. Header related page styles */

.mw-notification {
	top: 100px;
	border-color: #ddd;
	box-shadow: 2px 2px 5px rgba(0,0,0,.1);
	border-radius: 8px;
}

/* ------------ */
/* 2. Logo left */

#custom-header a.home {
	position: relative;
	width: 160px;
	height: 50px;
	display: inline-block;
}

#custom-header a.home:after {
	content: '';
	width: inherit;
	height: inherit;
	background-image: url('/w/images/thumb/d/d9/Kicksecure-text-logo.png/300px-Kicksecure-text-logo.png');
	background-size: 143px;
	background-repeat: no-repeat;
	background-position: 11px 10px;
	display: block;
}

#custom-header a.home:hover {
	transform: scale(1.1);
}

/* ------------ */
/* 3. Menu left */

#custom-header .nav-menu {
	display: inline-block;
	vertical-align: top;
	position: relative;
}

#custom-header .nav-menu .menu-title {
	display: none;
}

#custom-header .nav-menu .submenu {
	display: inline-block;
}

#custom-header .nav-menu .submenu > *, #custom-header .nav-menu .menu-title {
	height: 52px;
	font-size: 18px;
	line-height: 49px;
	padding: 0 6px;
	text-decoration: none;
	cursor: pointer;
	color: #444;
}

#custom-header .nav-menu .menu-title:hover {
	color: black;
}

#custom-header .nav-menu .submenu > * {
	display: inline-block;
}

#custom-header .nav-menu a:hover {
	transform: scale(1.1);
	color: black;
}

/* ------------- */
/* 4. Menu right */

#custom-header .menu-right {
	display: inline-block;
    float: right;
    height: 52px;
}

#custom-header .menu-right > * {
	vertical-align: top;
}

/* ----------- */
/* 5. Search */

#custom-header .search {
	width: 30px;
	height: 50px;
	display: inline-block;
	background-image: url('/w/images/2/25/Magnifying-glass.png');
	background-size: 26px;
	background-repeat: no-repeat;
	background-position-y: 12px;
	opacity: .7;
	cursor: pointer;
}

#custom-header .search:hover {
	opacity: 1;
	transform: scale(1.1);
}

/* ------------------------ */
/* 5.1. Search Form Modal */

#top-bar-search-modal .modal-dialog {
	max-width: 600px;
}

#top-bar-search-modal .modal-content {
	background: transparent;
	border: none;
}

#top-bar-search-modal .modal-header .close {
	font-size: 50px !important; 
	padding: 4px 10px 6px;
	text-shadow: none;
	cursor: pointer;
	background: transparent;
	color: #c1c1c1;
	opacity: 1;
	margin: 0 -26px -16px 0;
}

#top-bar-search-modal .modal-header .close:hover {
	text-shadow: 2px 2px 2px rgba(0,0,0,.3);
	color: white;
}

#top-bar-search-modal .modal-header, #top-bar-search-modal .modal-footer {
	border: none;
}

#top-bar-search-modal .modal-body {
	padding: 15px 0 0;
}

#top-bar-search-modal:not(.modal-initialized) .modal-body > * {
	opacity: 0;
}

#top-bar-search-modal #p-search > div {
	display: block !important;
}

#top-bar-search-modal #p-search > a.mw-ui-icon-wikimedia-search {
	display: none;
}

#top-bar-search-modal .wvui-typeahead-search {
	margin-left: 0; !important;
}

#top-bar-search-modal .wvui-input__start-icon {
	width: 50px !important;
	left: 1px !important;
}

#top-bar-search-modal .wvui-input__input {
	padding-left: 50px !important;
	height: 60px;
	border: none !important;
	font-size: 20px;
}

#top-bar-search-modal .wvui-typeahead-search__submit {
	opacity: 1 !important;
	background-color: #469bf0;
	border: none;
	color: white;
	font-size: 20px;
}

#top-bar-search-modal .wvui-typeahead-search__suggestions {
	top: 60px;
}

/* --------------- */
/* 6. Super Menu */

#custom-header .super-menu {
	width: 50px;
	height: 52px;
	display: inline-block;
	position: relative;
}

#custom-header .menu-title {
	width: 100%;
	height: 52px;
	background-size: 27px;
	background-repeat: no-repeat;
	background-position: 11px 17px;
	display: inline-block;
	opacity: .7;
	cursor: pointer;
}

#custom-header .menu-title:hover {
	opacity: 1;
}

#custom-header .super-menu .menu-title {
	background-image: url('/w/images/2/23/Chevron.png');
}

#custom-header .super-menu .submenus {
	background: white;
	padding: 0 10px 20px;
	width: max-content;
	position: absolute;
	right: -136px;
	top: 50px;
	text-align: left;
	border-radius: 0 0 10px 10px;
	border: 1px solid #ccc;
	border-top: none;
	display: none;	
}

#custom-header .super-menu:hover .submenus {
	display: block;
}

#custom-header .super-menu .submenus > * {
	display: inline-block;
	vertical-align: top;
	padding: 0 3px;
}

#custom-header .super-menu .submenus > * > * {
	display: block;
	padding: 4px 8px 3px 30px;
	text-decoration: none;
	color: #555;
	position: relative;
}

#custom-header .super-menu .submenus > * > *:before {
	position: absolute;
	font-family: 'Font Awesome 5 Free';
	font-weight: 900;
	top: 3px;
	left: 0;
	width: 29px;
	text-align: center;
}

#custom-header .super-menu .submenus > * > .headline {
	background: #f0f0f0;
	border-radius: 4px;
	cursor: default;
	padding-top: 11px;
	padding-bottom: 10px;
	margin: 5px 0;
}

#custom-header .super-menu .submenus .headline.user {
	max-width: 150px;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: pre;
}

#custom-header .super-menu .submenus > * > *:not(.headline):hover {
	color: black;
	background: #eee;
}

#custom-header .super-menu a.upload:before { content: '\f093'; }
#custom-header .super-menu a.special:before { content: '\f0d0'; }
#custom-header .super-menu a.recentchanges:before { content: '\f362'; }
#custom-header .super-menu a.print:before { content: '\f02f'; }

#custom-header .super-menu a.whatlinkshere:before { content: '\f1e0'; }
#custom-header .super-menu a.relatedchanges:before { content: '\f2f1'; }
#custom-header .super-menu a.info:before { content: '\f129'; }

#custom-header .super-menu a.view:before { content: '\f015'; }
#custom-header .super-menu a.edit:before { content: '\f304'; }
#custom-header .super-menu a.history:before { content: '\f1da'; }
#custom-header .super-menu a.move:before { content: '\f064'; }
#custom-header .super-menu a.protect:before { content: '\f3ed'; }
#custom-header .super-menu a.watch:before { content: '\f005'; font-weight: 400; }
#custom-header .super-menu a.unwatch:before { content: '\f005'; }
#custom-header .super-menu a.delete:before { content: '\f2ed'; }
#custom-header .super-menu a.purge:before { content: '\f7e4'; }

#custom-header .super-menu a.preferences:before { content: '\f069'; }
#custom-header .super-menu a.watchlist:before { content: '\f0cb'; }
#custom-header .super-menu a.contributions:before { content: '\f256'; }
#custom-header .super-menu a.logout:before { content: '\f13e'; }
#custom-header .super-menu a.createaccount:before { content: '\f067'; }
#custom-header .super-menu a.login:before { content: '\f2f6'; }

/* ----------------------- */
/* 6.1. User not logged in */

body:not(.user-logged-in) #custom-header .super-menu .user-logged-in { display: none; }
body.user-logged-in #custom-header .super-menu .user-logged-out { display: none; }
body.user-logged-in #custom-header .super-menu .headline.user { background-color: #c2dff9; }

body.page-is-watched #custom-header .super-menu .watch { display: none; }
body:not(.page-is-watched) #custom-header .super-menu .unwatch { display: none; }

/* ---------------- */
/* 7. Donate button */

#custom-header .donate {
	height: 40px;
	width: 120px !important;
	background-image: url('/w/images/d/d9/Heart.png');
	background-position: 6px 9px !important;
	background-repeat: no-repeat !important;
	background-size: 27px !important;
	font-size: 23px;
	font-weight: bold;
	line-height: 40px;
	padding: 0 0 0 40px;
	color: #686868;
	text-decoration: none;
	display: inline-block;
	text-align: left;
	margin-top: 5px;
}

#custom-header .donate:hover {
	background-size: 32px !important;
	background-position: 4px 7px !important;
	background-color: #f8f8f8 !important;
	color: black !important;
}

/* ----------------- */
/* 8. Mobile Version */

@media (max-width: 740px) {
	#custom-header .nav-menu .menu-title {
		display: inline-block;
	}
	
	#custom-header .nav-menu .menu-title:hover {
		opacity: 1;
	}

	#custom-header .nav-menu .submenu {
		position: absolute;
		left: -10px;
		top: 50px;
		border: 1px solid #ccc;
		border-top: none;
		background: white;
		border-radius: 0 0 8px 8px;
		overflow: hidden;
		display: none;
	}
	
	#custom-header .nav-menu:hover .submenu {
		display: block;
	}
	
	#custom-header .nav-menu .submenu > a {
		transform: none;
		padding: 0 15px;
		width: 100%;
	}
	
	#custom-header .nav-menu .submenu > *:hover {
		background: #eee;
	}
}

@media (max-width: 460px) {
	#custom-header a.home {
		width: 110px;
		font-size: 16px;
	}
	
	#custom-header a.home:after {
		background-size: 100px;
		background-position: 10px 10px;
	}
	
	#custom-header .search {
		background-position-x: 2px;
	}
	
	#custom-header div.super-menu {
		width: 34px;
	}
	
	#custom-header div.super-menu .menu-title {
		background-position: 4px 17px;
	}
	
	#custom-header .super-menu .submenus > * {
		padding: 0 !important;
	}	
	
	#custom-header .super-menu .submenus > * > * {
		font-size: 13px;
		margin-top: 7px;
		margin-bottom: 7px;
	}
	
	#custom-header a.donate {
		width: 113px !important;
		background-position-x: 16px !important;
		padding-left: 49px;
		font-weight: normal;
		font-size: 16px;
	}
	
	#custom-header a.donate:hover {
		background-position-x: 14px !important;
	}
}