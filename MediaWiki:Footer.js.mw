(function() {

	// Setup
	
	let fmodal = $('#footer-show-qr-codes-modal');
	fmodal.appendTo('body');
		
	$('#custom-footer .endorsements .project-news > div')
	.empty()
	.append( $('.project-random-news-ticker') );
	
	// Events
	
	$('#custom-footer .donate a:not(.donate-button)').on('click', function( e ) {
		fmodal.find('.modal-title').text( $(this).attr('title') );
		fmodal.find('.modal-body img').attr( 'src', $(this).children('img').attr('src') );
		fmodal.find('.modal-body .code-select .code').text( $(this).attr('data-address') );
		fmodal.modal('show');
		
		e.preventDefault();
	});
	
})();