@import url("/w/index.php?title=MediaWiki:Fonts2.css&action=raw&ctype=text/css");

/*
The styles in this file are only activated if the user has Javascript deactivated.
This file is shared via MultiWiki. Only site specific Nojs CSS is found in [[MediaWiki:Nojs_SiteSpecific.css]]
*/

/* 0. General classes */

.show-for-nojs-only {
	display: block;
}

.show-for-js-only {
	display: none;
}

/* 1. CodeSelect */

.code-select {
	font-family: Courier, monospace;
	font-size: 14px;
	color: #0054a8;
	line-height: 1.6em;
	width: 100%;
	overflow: auto;
	white-space: pre;
	padding: 4px 13px 2px 15px;
	cursor: auto !important;
}

/* 2. Pay via Paypal module */

.pay-via-paypal-module {
	display: block;
}

/* 3. Expand/Collapse All button */

.expand-or-collapse-all-button {
	display: none;	
}

