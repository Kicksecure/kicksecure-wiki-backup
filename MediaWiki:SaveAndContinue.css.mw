#editform .save-and-continue {
	display: inline-block;
	padding: 4px 14px;
	margin-right: 8px;
	vertical-align: bottom;
	background: #018001;
	color: white;
	font-weight: bold;
	cursor: pointer;
	border: 1px solid #406040;
}

#editform .save-and-continue:hover {
	background: #1ab01a;
}

#saveAndContinueMiniModal {
	width: 100%;
	height: 100vh;
	position: fixed;
	left: 0;
	top: 0;
}

#saveAndContinueMiniModal:not(.active) {
	display: none;
}

#saveAndContinueMiniModal .underlay {
	background-color: rgba(0,0,0,.5);
	width: 100%;
	height:100%;
	position: absolute;
	cursor: pointer;
	opacity: 1;
	transition: background-color .5s;
}

#saveAndContinueMiniModal .underlay:hover {
	background-color: rgba(0,0,0,.3);
}

#saveAndContinueMiniModal .underlay > i {
	position: absolute;
	right: 27px;
	top: 16px;
	font-size: 73px;
	color: white;
	text-shadow: 1px 2px 3px rgba(0,0,0,.4);
}

#saveAndContinueMiniModal .underlay:hover > i {
	color: #ff89a5;
}

#saveAndContinueMiniModal iframe {
	position: absolute;
	left: 100px;
	top: 100px;
	width: calc(100% - 200px);
	height: calc(100% - 200px);
	border: none;
	box-shadow: 3px 3px 10px rgba(0,0,0,.3);
}
