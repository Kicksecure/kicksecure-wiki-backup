(function() { setTimeout( function() {
	
	// -----
	// Setup
	
	// Transform Search to Vector Skin
	
	$('#top-bar-search-modal #searchInput').focus();
	
	//  Copy SearchForm to Modal
	
	let search = $('.mw-header #p-search');
	$('body').append($('#top-bar-search-modal'));

	$('#top-bar-search-modal .modal-body').append( search );
	
	// Setup of super menu by current user status and watching status
	
	if( $('#pt-userpage').length > 0 ) {
		$('#custom-header .super-menu .headline.user').text('User: ' + $('#pt-userpage > a').text() );
		$('body').addClass('user-logged-in');
	}
	
	if( $('#ca-unwatch').length != 0 ) {
		$('body').addClass('page-is-watched');
	}
	
	// ------
	// Events
	
	// Event: Search Button click
	
	$('#custom-header .search').on( 'click', function(e) {
		$('#top-bar-search-modal').modal('show');
		e.preventDefault();
	});
	
	// Events
	
	$('#top-bar-search-modal').on('shown.bs.modal', function() {
		if( ! $('#top-bar-search-modal').hasClass('modal-initialized') ) {
			$('#top-bar-search-modal #searchInput').focus();
		}
		
		search.find('input.wvui-input__input').val('');
		search.find('input.wvui-input__input').focus();
	});
	
	$('#top-bar-search-modal').on('shown.bs.modal', function() {
		$('#top-bar-search-modal').addClass('modal-initialized');
	});
	
}, 500 ) })();