(function() {{
	/*
	Documentation
	Author:  Hans
	Since:   2022-01-20
	Version: 2022-01-20
	-------------------
	1. Transforms chosen elements in content area and gives them an indicator, if they are scrollable to the right (useful for mobile)
	*/
	
	setTimeout( function() {
		
		// Setup
		
		$('div.scroll-table').each( function() {
			if( $(this).width() < $(this).prop('scrollWidth') ) {
				$(this).addClass('scroll-overflow-indicator')
			}
		});
		
	}, 0 );


}})();
