/* CSS for Widget:Download_Button */

.download-button-v2 {
	display: inline-block;
	border-radius: 50px;
	position: relative;
	background: #eee;
	transition: background-color .3s, border-color .3s;
	max-width: 100%;
	box-shadow: inset 0 0 4px rgba(0,0,0,.05);
}
.download-button-v2:hover {
	background: #e4e4e4;
	border-color: #cdcdcd;
}
.download-button-v2:hover .dbutton {
	background-image: linear-gradient( #4180d1 0%, #005aae 100%);
	color: white;
}

.download-button-v2 .dbutton {
	display: table-cell;
	border-radius: 50px;
	background-image: linear-gradient( #4d8cdd 0%, #0867bb 100%);
	position: relative;
	padding: 7px 25px 7px 69px;
	color: #eaf1ff;
	font-weight: bold;
	transition: color .3s, background-image .3s;
	text-align: center;
}

.download-button-v2 .dbutton:before {
	content: '';
    height: calc( 100% - 1px );
    position: absolute;
    border-right: 1px solid #7bb1ea;
    top: 0;
    left: 58px;
}

.download-button-v2 .dbutton > i {
    padding: 11px 14px 0 0;
    position: absolute;
    left: 25px;
    top: calc( 50% - 19px );
    height: calc( 100% - 1px );
}

.download-button-v2 .dbutton > span {
	position: relative;
	top: -2px;
}


.download-button-v2 .op-sys {
	display: table-cell;
	text-align: center;
	position: relative;
	top: -2px;
	padding: 0 15px 0 10px;
}

.download-button-v2 .op-sys > img {
	margin: 0;
	margin-right: 6px;
	position: relative;
}
.download-button-v2 .op-sys > img:last-child {
	margin-right: 0;
}
.download-button-v2 .op-sys > img.osx,
.download-button-v2 .op-sys > img.virtualbox {
	top: -1px;
}

/* Mobile Tweaks */

@media (max-width: 450px) {
	.download-button-v2 {
		font-size: 13px;
		padding-right: 12px;
	}
	
	.download-button-v2 .dbutton {
		padding: 6px 16px 6px 50px;
	}
	
	.download-button-v2 .dbutton:before {
		left: 43px;
	}
	
	.download-button-v2 .dbutton > i {
		padding: 11px 9px 0 0;
		left: 17px;
	}
	
	.download-button-v2 .op-sys > img {
		height: 16px;
	}
}
