/* Mini navigation is used to have multiple buttons in a row linking to other pages */

.mininav {
	margin: 15px 0;
}

.mininav ul {
	list-style: none;
	padding-left: 0 !important;
	margin-left: 0 !important;
	display: inline-block;
	font-size: 0;
}

.mininav li {
	display: inline-block;
	padding: 0 !important;
	margin-bottom: 5px;
}

.mininav li a {
	background-color: #fafafa;
	padding: 9px 15px;
	text-decoration: none;
	font-size: 17px !important;
	color: #36b;
	display: inline-block;
	border-bottom: 4px solid white;
	transition: background-color .3s, border-bottom-color .3s;
}

.mininav li:not(:last-child) a {
	margin-right: 3px;
}

.mininav li a:hover, .mininav li a.selflink {
	background-color: white;
	border-bottom-color: #89d;
	box-shadow: 2px 2px 3px rgba(0,0,0,.05);
}

/* For smaller display */

@media (max-width: 420px) {
	.mininav li a {
		font-size: 15px !important;
		padding: 6px 10px;
	}
}

