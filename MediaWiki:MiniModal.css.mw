.mini-modal {
	width: 100%;
	height: 100vh;
	position: fixed;
	left: 0;
	top: 0;
}

.mini-modal:not(.active) {
	display: none;
}

.mini-modal .underlay {
	background-color: rgba(0,0,0,.5);
	width: 100%;
	height:100%;
	position: absolute;
	cursor: pointer;
	opacity: 1;
	transition: background-color .5s;
}

.mini-modal .underlay:hover {
	background-color: rgba(0,0,0,.3);
}

.mini-modal .underlay > i {
	position: absolute;
	right: 27px;
	top: 16px;
	font-size: 73px;
	color: white;
	text-shadow: 1px 2px 3px rgba(0,0,0,.4);
}

.mini-modal .underlay:hover > i {
	color: #ff89a5;
}