/* This script removes the ugly [dismiss] button from Extension:DismissableSiteNotice and replaces it with FontAwesome graphical X */

(function() {

	// Setup

	let wrapper = $('#siteNotice .mw-dismissable-notice-close');
	let close = wrapper.children('a');
	
	// Add title
	close.attr('title','Hide this notice for me');

	// Replace with Icon
	close.html('<i class="fas fa-times"></i>');

	// remove brackets []
	wrapper.contents().filter(function() {
		return this.nodeType == 3; //Node.TEXT_NODE
	}).remove();

	// show wrapper
	wrapper.css('display','block');

})();

