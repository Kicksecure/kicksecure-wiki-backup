(function() {
	
	// Functions
	
	function init( $this ) {
		$this.each( function() {
			if( $this.hasClass('init-complete') ) return;
			else $this.addClass('init-complete');
			
			let content = $this.children();
			
			$this.empty().append(''
				+ '<div class="underlay">'
				+  '<i class="fas fa-times"></i>'
				+ '</div>'
				+ '<div class="content" />'
			);
			
			$this.children('.content').append( content );
			
			// Events
			
			$this.children('.underlay').on( 'click', function() {
				$this.miniModal('hide');
			});
		});
	}
	
	// Setup
	
	$.fn.miniModal = function(command) {
		switch( command ) {
			case 'show':
				init($(this));
				$(this).addClass('active');
			break;
			case 'hide':
				init($(this));
				$(this).removeClass('active');
			break;
			case 'init':
				init($(this));
			break;
		}
	}
	
})();

