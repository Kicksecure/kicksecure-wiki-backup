/* --------- */
/* 1. Global */

body {
	background: #f3f3f3;
	font-family: 'Roboto';
}

a {
	overflow-wrap: break-word;
}

pre, code, div.pre {
	font-family: 'Cousine', monospace, Courier !important;
	font-size: 13px;
	color: #444;
}

pre, div.pre {
	white-space: pre;
	background-color: rgb(221,221,221);
	margin-bottom: 1em;
	width: 100%;
	padding: 1em;
	line-height: 1.3em;
	overflow: auto;
}

code {
	background-color: #f5f5f5;
	border-color: #e3e3e3;
	border-radius: 3px;
	color: #222;
	padding: 3px 7px;
	margin-left: -1px;
}

div.pre p {
	font-size: 13px !important;
	margin: 0 !important;
}

/* 1.1. Classes */

.modal {
	/* makes position: fixed work on old mobile web browsers */
	-webkit-backface-visibility: hidden;
}

.width-100 {
	width: 100%;
}

.margin-left-5 { margin-left: 5px; }
.margin-left-10 { margin-left: 10px; }
.margin-left-20 { margin-left: 20px; }
.margin-right-5 { margin-right: 5px; }
.margin-right-10 { margin-right: 10px; }
.margin-right-20 { margin-right: 20px; }
.margin-top-5 { margin-top: 5px; }
.margin-top-10 { margin-top: 10px; }
.margin-top-20 { margin-top: 20px; }
.margin-bottom-5 { margin-bottom: 5px; }
.margin-bottom-10 { margin-bottom: 10px; }
.margin-bottom-20 { margin-bottom: 20px; }

.pos-1px-up { position: relative; top: -1px; }
.pos-1px-down { position: relative; top: 1px; }
.pos-2px-up { position: relative; top: -2px; }
.pos-2px-down { position: relative; top: 2px; }
.pos-3px-up { position: relative; top: -3px; }
.pos-3px-down { position: relative; top: 3px; }

.text-align-center {
	text-align: center;
}

.vertical-align-middle {
	vertical-align: middle;
}

.clear-float {
	clear: both;
	float: none;
	overflow: auto;
}

/* 1.2. Scrollbar mobile */

::-webkit-scrollbar {
    -webkit-appearance: none;
}

::-webkit-scrollbar:vertical {
    width: 12px;
}

::-webkit-scrollbar:horizontal {
    height: 12px;
}

::-webkit-scrollbar-thumb {
    background-color: rgba(0, 0, 0, .5);
    border-radius: 10px;
    border: 2px solid #ffffff;
}

::-webkit-scrollbar-track {
    border-radius: 10px;
    background-color: #ffffff;
}

/* 1.3. Container elements */

.mw-page-container {
	background: transparent;
	padding: 0;
	max-width: unset;
	min-width: unset !important;
}

#mw-page-base {
	background: transparent;
	height: 45px;
}

/* --------------------- */
/* 2. Navigation related */

#contentSub {
	margin-left: 0;
}

#contentSub .subpages {
	font-size: 15px;
	padding: 6px 8px 7px 4px;
	border-bottom: 2px solid white;
	display: inline-block;
}

#contentSub .subpages, #contentSub .subpages a {
	color: #36b;
}

#mw-navigation, #catlinks {
	display: none;
}

/* Fix overlapping of fixed header on page target jumps */

html, body {
	scroll-padding-top: 70px;
}

.mw-headline {
	padding-top: 70px;
	background-color: transparent !important;
}

sup[id^=cite_ref-] {
	padding-top: 90px;
	background-color: transparent !important;
}

li[id^=cite_note-]:target {
	content: '';
	padding-top: 70px;
	margin-top: -70px;
	background-color: transparent !important;
}

li[id^=cite_note-]:target > .reference-text {
	background-color: #ececec;
}

.manually-placed-anchor {
	position: relative;
	top: -40px;
}

/* ----------------- */
/* 3. Content styles */

body.modal-open {
    overflow: visible;
}

.thumb {
	margin-top: 0 !important;
	max-width: 100%;
	vertical-align: top;
}
	
.thumb .thumbinner {
	border-radius: 5px;
	padding: 5px !important;
	max-width: 100%;
}

.thumb .thumbinner a.image {
	width: 100%;
	display: block;
}

.thumb .thumbinner img {
	max-width: 100%;
	height: auto;
}

.thumb .thumbimage.hide-enlarge + .thumbcaption {
	text-align: center;
}

.thumb .thumbimage.hide-enlarge + .thumbcaption .magnify {
	display: none;
}

.mw-workspace-container {
	max-width: unset;
}

.mw-content-container {
	max-width: unset;
	margin-left: unset !important;
}

#content {
	background: none;
	border: none;
	max-width: 960px;
	width: 100%;
	margin: auto;
	padding: 0 12px;
}

#bodyContent {
	position: unset;
}

#mw-content-text h1, #mw-content-text h2, #mw-content-text h3, #mw-content-text h4, #mw-content-text h5, #mw-content-text h6 {
	padding-bottom: .18em;
	color: #333;
	border-color: #777;
	background: transparent;
	font-family: 'Roboto';
	margin-top: 1.1em;
	margin-bottom: .9em;
}


#mw-content-text p {
	font-size: 15px;
}

#mw-content-text a {
	font-size: inherit;
}

#mw-content-text #custom-header ~ * a:visited {
	color: #0645ad;
}

#mw-content-text p {
	margin-top: .85em;
	margin-bottom: .85em;
	color: #444;
}

#mw-content-text ul, #mw-content-text ol {
	margin: .2em 0 .2em 1em;
}

#mw-content-text ul.gallery {
	margin-left: -5px;
}

#mw-content-text ul.gallery div.gallerytext p {
	margin: 0;
	color: #707070;
	text-align: center;
	font-style: italic;
}

#mw-content-text ul.gallery a:hover img {
	transform: scale(1.1);
}

#mw-content-text ol {
	margin-left: 1.25em;
}

#mw-content-text li {
	padding-left: .2em;
	font-size: 15px;
	color: #444;
}

/* Blockquote */

#mw-content-text blockquote {
	padding: 11px 22px;
	border-left: 7px solid #ddd ;
}

#mw-content-text blockquote *:first-child {
	margin-top: 0 !important;
}
#mw-content-text blockquote *:last-child {
	margin-bottom: 0 !important;
}

#mw-content-text a.image img {
	max-width: 100%;
	height: auto;
}

/* Info-Box (mbox) */

#mw-content-text .info-box {
	padding: 5px 21px;
	margin: 13px 0 13px -2px;
	border: 1px solid #e0e0e0;
	background: white;
	border-radius: 8px;
	box-shadow: 2px 2px 5px rgb(0, 0, 0, .09);
	display: flow-root;
}

#mw-content-text .info-box .image {
	margin-right: 7px;
}

/* Expand/ Collapse Button */

#mw-content-text .mw-collapsible {
	border-radius: 8px;
	padding: 3px 18px;
	margin: 18px 0px;
	overflow: auto;
	border-color: #ccc;
}

#mw-content-text .mw-collapsible .mw-collapsible-toggle, .expand-or-collapse-all-button {
	padding: 4px 17px 5px 10px;
	border-radius: 5px;
	line-height: 30px;
	margin: 5px 0;
	border: none;
	background: #4180d1;
	margin-right: -9px;
	color: white;
	font-weight: bold;
}

#mw-content-text .mw-collapsible .mw-collapsible-toggle {
	margin-left: 5px;
}

#mw-content-text .mw-collapsible .mw-collapsible-toggle:hover, .expand-or-collapse-all-button:hover {
	background-color: #2f6ebf;
}

#mw-content-text .mw-collapsible .mw-collapsible-toggle a {
	color: white;
	text-decoration: none;
}

#mw-content-text .mw-collapsible .mw-collapsible-toggle:before, .expand-or-collapse-all-button.all-expanded:before {
	content: '▲';
	margin-right: 5px;
	font-size: 16px;
}

#mw-content-text .mw-collapsible.mw-collapsed .mw-collapsible-toggle:before, .expand-or-collapse-all-button:not(.all-expanded):before {
	content: '▼';
}

#mw-content-text .mw-collapsible .mw-collapsible-toggle:after {
	content: '';	
}

.expand-or-collapse-all-button:not(.all-expanded) .collapse-text { display: none; }
.expand-or-collapse-all-button.all-expanded .expand-text { display: none; }

/* Table */

#mw-content-text .scroll-table {
	overflow-x: auto;
	max-width: 100%;
	position: relative;
	margin: 1em 0;
}

#mw-content-text .scroll-table table {
	margin: 0;
}

#mw-content-text .scroll-table.scroll-overflow-indicator {
	padding-bottom: 11px;
}

#mw-content-text .scroll-table.scroll-overflow-indicator:before, #mw-content-text .scroll-table.scroll-overflow-indicator:after {
	content: 'swipe >>';
	display: block;
	width: 100%;
	padding: 2px 15px 5px;
	color: white;
	background: linear-gradient( to right, #6ab9ff 30%, transparent);
	border-radius: 4px;
	font-size: 17px;
}

#mw-content-text .wikitable {
	background: transparent;
	border-collapse: separate;
	border: none;
	border-spacing: 3px;
	margin-left: -4px !important;
}

#mw-content-text .wikitable th, #mw-content-text .wikitable td {
	border: none;
	border-radius: 4px;
	box-shadow: 0 0 3px rgba(255,255,255,.3);
	padding: 10px 15px;
}

#mw-content-text .wikitable th {
	background: #dfdfdf;
	vertical-align: top;
}
	
#mw-content-text .wikitable td {
	background: #ebebeb;
}

/* First Heading, table of contents */

#firstHeading, #toc {
	background: white;
	border-radius: 8px;
	box-shadow: 2px 2px 5px rgb(0, 0, 0, .09);
	border: 1px solid #e0e0e0;
}

#firstHeading {
	width: max-content;
	max-width: 100%;
	padding: 10px 29px 11px;
	font-size: 1.5em;
	margin: 25px 0px 25px -2px;
	font-family: 'Roboto';
	color: #444;
}

#toc {
	padding: 25px 30px 25px 20px;
	margin: 0 0 0 -2px;
	font-size: 100%;
}

#toc .toctitle {
	text-align: left;
	margin-left: 17px;
}

#toc .toctitle h2 {
	color: #444;
	font-family: 'Roboto';
	font-size: 18px;
	font-weight: normal;
}

#toc .toctitle .toctogglespan {
	padding-left: 8px;
}

#toc .toctitle .toctogglespan:before, #toc .toctitle .toctogglespan:after {
	position: relative;
	top: -1px;
}

#toc .toctitle .toctogglelabel {
	font-size: 18px;
	padding: 0 6px 0 8px;
	outline: none;
}

#toc .toctitle .toctogglelabel:after {
	content: 'collapse ↑';
}

#toc #toctogglecheckbox:checked ~ .toctitle .toctogglelabel:after {
	content: 'expand ↓';
}


#toc .tocnumber {
	padding-right: .9em;
	color: #4F4F4F;
	-webkit-touch-callout: none;
	-webkit-user-select: none;
	-khtml-user-select: none;
	-moz-user-select: none;
	-ms-user-select: none;
	user-select: none;
}

#toc > ul {
	margin-bottom: 0;
}

#toc ul ul {
	margin: 0 0 0 1.5em;
}

#toc a {
	line-height: 25px;
}

/* 3.2. Footer area */

#mw-data-after-content #mw-fr-reviewform  {
	display: none;
}

#footer {
	display: none;
}

/* -------------------------------- */
/* 4. Edit Preview improve editform */

body.action-submit #editform {
	position: relative;
	z-index: 1000;
	background: #f6f3f4;
	padding: 10px;
	border: 1px solid #ccc;
}

/* ---------------- */
/* 5. No-JS classes */

.show-for-nojs-only {
	display: none;
}

.show-for-js-only {
	display: block;
}

/* ---------- */
/* 6. Columns */

.use-3-columns {
	column-count: 3;
	column-gap: 20px;
	column-rule: 1px solid #ddd;
	width: 100%;
	margin: 15px 0;
}
.use-3-columns .keep-together {
	display: inline-block;
	vertical-align: top;
}
.use-3-columns.strict-list-columns > ul,
.use-3-columns.strict-list-columns > ol {
	display: inline-block;
}
/* Responsive */
@media (max-width: 590px) {
	.use-3-columns {
		column-count: 2;
	}
}
@media (max-width: 450px) {
	.use-3-columns {
		column-count: 1;
	}
}

